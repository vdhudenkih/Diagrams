Смотри, текущая программа лемматизирует слова и даёт их в файл. Измени (и оптимизируй) её таким образом, 
чтобы в выходной файл она собирала статистику формата id_lemma|lemma|часть речи(тэг, не переведенный на русский язык)|частота встречи леммы в входном файле
программа:



using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Text;
using System.Text.RegularExpressions;

class Lemmatizer
{
    // Статистика: ключ = "id|лемма|часть речи", значение = частота
    static Dictionary<string, int> statistics = new Dictionary<string, int>();

    static void Main()
    {
        string[] testData = ProcessFile("input.txt");

        foreach (string line in testData)
        {
            string inputString = line.ToLower();
            inputString = inputString.Replace(".", ". ");
            inputString = inputString.Replace(" - ", " ");
            inputString = inputString.Replace("(", " ");
            inputString = inputString.Replace(")", " ");
            inputString = inputString.Replace("|", "");

            string[] inputMaterials = inputString.Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
            string[] inputMaterialsProcessed = ProcessHyphen(inputMaterials);
            List<Word> words = new List<Word>();

            for (int i = 0; i < inputMaterialsProcessed.Length; i++)
            {
                bool devidedHyphen = false;
                if (inputMaterialsProcessed[i].Contains("-"))
                    inputMaterialsProcessed[i] = inputMaterialsProcessed[i].Replace("-", "@");
                else if (inputMaterialsProcessed[i].Contains("Y"))
                {
                    devidedHyphen = true;
                    inputMaterialsProcessed[i] = inputMaterialsProcessed[i].Replace("Y", "");
                }

                string[] lemmas = SearchInDictionary(inputMaterialsProcessed[i])
                    .Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

                foreach (string lemmaEntry in lemmas)
                {
                    string[] list = lemmaEntry.Split(new char[] { '-' }, StringSplitOptions.RemoveEmptyEntries);
                    // Пропускаем мусорные сокращения (2-ух, 8-ми и т.п.)
                    if (list.Length >= 6 && list[1] != "х" && list[1] != "ми" && list[1] != "ти" && list[1] != "ух")
                    {
                        if (list[1].Contains("@"))
                            list[1] = list[1].Replace("@", "-");

                        string spec = devidedHyphen ? "Y" : "0000";
                        Word w = new Word(list[0], i, list[1], list[2], list[3], list[4], list[5], list[6], spec);
                        words.Add(w);

                        // ----- СОБИРАЕМ СТАТИСТИКУ -----
                        // Получаем лемму (нормальную форму) по ID и части речи
                        string lemma = GetLemmaFromId(w.wordId);
                        string pos = w.partOfSpeech;
                        string key = string.Format("{0}|{1}|{2}", w.wordId, lemma, pos);
                        if (statistics.ContainsKey(key))
                            statistics[key]++;
                        else
                            statistics[key] = 1;
                        // --------------------------------
                    }
                    else
                    {
                        // Несловарное слово – пропускаем (не добавляем в статистику)
                        break;
                    }
                }
            }
            words.Clear();
        }

        // Сохраняем статистику
        SaveStatistics("statistics.txt");
        Console.WriteLine("Готово. Статистика сохранена в statistics.txt");
        Console.ReadLine();
    }

    // ---------- ОРИГИНАЛЬНЫЕ МЕТОДЫ (НЕ ИЗМЕНЕНЫ) ----------
    static string[] ProcessHyphen(string[] words)
    {
        for (int i = 0; i < words.Length; i++)
        {
            if (words[i].Contains("-"))
            {
                if (SearchInDictionary("&" + words[i]) == "0")
                {
                    string[] inputMaterialsHyphen = words[i].Split(new char[] { '-' }, StringSplitOptions.RemoveEmptyEntries);
                    words[i] = "Y" + inputMaterialsHyphen[0];
                    string[] newInputMaterials = { };
                    for (int j = 1; j < inputMaterialsHyphen.Length; j++)
                    {
                        newInputMaterials = InsertElementAfterIndex(words, "Y" + inputMaterialsHyphen[j], i + j - 1);
                        words = newInputMaterials;
                    }
                    return newInputMaterials;
                }
            }
        }
        return words;
    }

    static T[] InsertElementAfterIndex<T>(T[] originalArray, T newElement, int insertIndex)
    {
        T[] newArray = new T[originalArray.Length + 1];
        Array.Copy(originalArray, 0, newArray, 0, insertIndex + 1);
        newArray[insertIndex + 1] = newElement;
        if (insertIndex + 1 < originalArray.Length)
            Array.Copy(originalArray, insertIndex + 1, newArray, insertIndex + 2, originalArray.Length - (insertIndex + 1));
        return newArray;
    }

    static string[] ProcessFile(string filePath)
    {
        var lines = File.ReadAllLines(filePath);
        for (int i = 0; i < lines.Length; i++)
        {
            int index = lines[i].IndexOf('\\');
            if (index >= 0) lines[i] = lines[i].Substring(0, index);
            index = lines[i].IndexOf('/');
            if (index >= 0) lines[i] = lines[i].Substring(0, index);
        }
        return lines;
    }

    static string SearchInDictionary(string word)
    {
        bool wordCheck = false;
        if (word.Contains("&"))
        {
            wordCheck = true;
            word = word.Substring(1);
        }

        string[] dictionaryNumbers = { "", "ёеаб", "бв", "вг", "гдежз", "зи", "ийкл", "лмн", "но", "о", "оп", "п", "пр", "рс", "с", "сту", "уфх", "хцчшщэюя" };
        string dictionaryNumber = "";
        for (int i = 0; i < dictionaryNumbers.Length; i++)
        {
            if (dictionaryNumbers[i].Contains(word[0].ToString()))
            {
                dictionaryNumber += "-";
                dictionaryNumber += i;
            }
        }

        if (word.Contains("-") || word.Contains("@"))
            dictionaryNumber += "-17";
        if (word.Contains("е") || word.Contains("ё"))
        {
            dictionaryNumber += "-E";
            word = word.Replace("ё", "е");
        }

        string[] foundDictionaries = dictionaryNumber.Split(new char[] { '-' }, StringSplitOptions.RemoveEmptyEntries);
        string lemmas = "";

        for (int i = 0; i < foundDictionaries.Length; i++)
        {
            string filePath = "lemmas" + foundDictionaries[i] + ".txt";
            if (!File.Exists(filePath)) continue;
            if (word.Contains("@")) word = word.Replace("@", "-");

            string[] fileContent = File.ReadAllLines(filePath);
            string[] strSearch = fileContent.Where(s => s.Contains("\"" + word + "\"")).ToArray();

            if (strSearch.Length == 0 && word.Contains("-") && wordCheck)
                return "0";
            else if (strSearch.Length != 0 && word.Contains("-") && wordCheck)
                return "1";

            foreach (string str in strSearch)
            {
                var parsedLemmas = ParseLemma(word, str);
                foreach (string lemma in parsedLemmas)
                    lemmas += lemma + " ";
            }
        }
        return string.IsNullOrEmpty(lemmas) ? "не найдено" : lemmas.Trim();
    }

    static List<string> ParseLemma(string inputWord, string lemmaXml)
    {
        var result = new List<string>();

        var lemmaIdMatch = Regex.Match(lemmaXml, @"<lemma id=""(\d+)""");
        string lemmaId = lemmaIdMatch.Success ? lemmaIdMatch.Groups[1].Value : "0000";

        // Извлекаем лемму (нормальную форму) из тега <l t="...">
        string lemmaForm = "0000";
        Match lemmaFormMatch = Regex.Match(lemmaXml, @"<l t=""([^""]+)""");
        if (lemmaFormMatch.Success)
            lemmaForm = lemmaFormMatch.Groups[1].Value;

        var forms = Regex.Matches(lemmaXml, @"<f t=""([^""]+)"">(.*?)</f>");
        var lemmaMatch = Regex.Match(lemmaXml, @"<l t=""[^""]+"">(.*?)</l>");
        var lemmaTags = Regex.Matches(lemmaMatch.Groups[1].Value, @"<g v=""([^""]+)""")
            .Cast<Match>().Select(t => t.Groups[1].Value).ToList();

        string posTag = lemmaTags.FirstOrDefault(t => t == "NOUN" || t == "ADJF" || t == "VERB" || t == "PREP" || t == "PRTF" ||
            t == "NUMR" || t == "CONJ" || t == "PRCL" || t == "COMP" || t == "GRND" || t == "INFN" || t == "PRTS" ||
            t == "ADVB" || t == "ADJS" || t == "NPRO" || t == "PRED" || t == "INTJ") ?? "0000";

        foreach (Match form in forms)
        {
            string formWord = form.Groups[1].Value;
            if (formWord == inputWord)
            {
                var tags = Regex.Matches(form.Groups[2].Value, @"<g v=""([^""]+)""");
                var tagList = tags.Cast<Match>().Select(t => t.Groups[1].Value).ToList();

                // Вместо inputWord сохраняем нормальную форму (лемму)
                string wordForResult = lemmaForm;   // <--- вот здесь лемма
                string baseResult = string.Format("{0}-{1}-{2}", lemmaId, wordForResult, posTag);

                if (posTag == "VERB")
                {
                    string genderTag = tagList.FirstOrDefault(t => new[] { "masc", "femn", "neut" }.Contains(t)) ?? "0000";
                    baseResult += string.Format("-0000-0000-{0}", genderTag);
                    string numberTag = tagList.FirstOrDefault(t => new[] { "sing", "plur" }.Contains(t)) ?? "0000";
                    baseResult += string.Format("-{0}", numberTag);
                }
                else
                {
                    string caseTag = tagList.FirstOrDefault(t => new[] { "nomn", "gent", "datv", "accs", "ablt", "loct" }.Contains(t)) ?? "0000";
                    baseResult += string.Format("-{0}", caseTag);
                    string animTag = lemmaTags.Contains("anim") ? "anim" : lemmaTags.Contains("inan") ? "inan" : "0000";
                    baseResult += string.Format("-{0}", animTag);
                    string genderTag = lemmaTags.FirstOrDefault(t => new[] { "masc", "femn", "neut" }.Contains(t)) ?? "0000";
                    baseResult += string.Format("-{0}", genderTag);
                    string numberTag = tagList.FirstOrDefault(t => new[] { "sing", "plur" }.Contains(t)) ?? "0000";
                    baseResult += string.Format("-{0}", numberTag);
                }
                result.Add(baseResult);
            }
        }
        return result;
    }

    // Получение леммы по ID (читает XML из того же файла словаря)
    static string GetLemmaFromId(string wordId)
    {
        int id = int.Parse(wordId);
        string fileName = GetFileNameById(id);
        if (fileName == "не словарное слово" || !File.Exists(fileName))
            return "???";

        using (XmlReader reader = XmlReader.Create(fileName))
        {
            while (reader.Read())
            {
                if (reader.NodeType == XmlNodeType.Element && reader.Name == "lemma")
                {
                    string lemmaId = reader.GetAttribute("id");
                    if (lemmaId == wordId)
                    {
                        string lemmaXml = reader.ReadOuterXml();
                        Match m = Regex.Match(lemmaXml, @"<l t=""([^""]+)""");
                        if (m.Success)
                            return m.Groups[1].Value;
                    }
                }
            }
        }
        return "???";
    }

    static string GetFileNameById(int id)
    {
        if (id >= 1 && id <= 25000) return "lemmas1.txt";
        if (id >= 25001 && id <= 50000) return "lemmas2.txt";
        if (id >= 50001 && id <= 75000) return "lemmas3.txt";
        if (id >= 75001 && id <= 100500) return "lemmas4.txt";
        if (id >= 100501 && id <= 125000) return "lemmas5.txt";
        if (id >= 125001 && id <= 150000) return "lemmas6.txt";
        if (id >= 150001 && id <= 175000) return "lemmas7.txt";
        if (id >= 175001 && id <= 195600) return "lemmas8.txt";
        if (id >= 195601 && id <= 219999) return "lemmas9.txt";
        if (id >= 220000 && id <= 244000) return "lemmas10.txt";
        if (id >= 244001 && id <= 268000) return "lemmas11.txt";
        if (id >= 268001 && id <= 291000) return "lemmas12.txt";
        if (id >= 291001 && id <= 315500) return "lemmas13.txt";
        if (id >= 315501 && id <= 340000) return "lemmas14.txt";
        if (id >= 340001 && id <= 362000) return "lemmas15.txt";
        if (id >= 362001 && id <= 372000) return "lemmas16.txt";
        if (id >= 372001 && id <= 417260) return "lemmas17.txt";
        if (id >= 999999) return "не словарное слово";
        throw new ArgumentException("Неизвестный диапазон id: " + id);
    }

    static void SaveStatistics(string filePath)
    {
        // Сортируем по id леммы (числовому)
        var sorted = statistics.OrderBy(kvp => int.Parse(kvp.Key.Split('|')[0]));
        using (StreamWriter sw = new StreamWriter(filePath))
        {
            foreach (var kvp in sorted)
                sw.WriteLine(kvp.Key + "|" + kvp.Value);
        }
    }
}

// Класс Word – без изменений, но добавим поле lemma (можно не использовать, т.к. статистика собирается отдельно)
class Word
{
    public string wordId;
    public int wordOrder;
    public string wordText;
    public string partOfSpeech;
    public string wordCase;
    public string animation;
    public string wordKind;
    public string singPlur;
    public string specMarks;

    public Word(string WordId, int WordOrder, string WordText, string PartOfSpeech,
                string WordCase, string Animation, string WordKind, string SingPlur, string SpecMarks)
    {
        wordId = WordId;
        wordOrder = WordOrder;
        wordText = WordText;
        partOfSpeech = PartOfSpeech;
        wordKind = WordKind;
        singPlur = SingPlur;
        wordCase = WordCase;
        animation = Animation;
        specMarks = SpecMarks;
    }
}